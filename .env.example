# WhatsApp deep-link number, digits only with country code, no + or spaces.
# Never hardcode this in component markup — see 07-development-handoff/claude-code-project-brief.md §3.
NEXT_PUBLIC_WHATSAPP_NUMBER=15551234567

# Resend API key the /api/lead route uses to email audit and contact form
# submissions. Server-only — never prefix with NEXT_PUBLIC_. The "from" address
# in app/api/lead/route.ts must be on a domain verified in the Resend dashboard,
# or sends will fail.
RESEND_API_KEY=re_your_api_key

# Where /api/lead actually delivers form/booking notifications. Server-only,
# deliberately separate from lib/nav.ts's CONTACT_EMAIL (hello@itsumair.com),
# which is the address shown publicly on the site. This one never appears in
# any visible page content.
LEAD_NOTIFICATION_EMAIL=you@example.com

# Cal.com booking link used by the "Book a 20-Minute Visibility Review" embed.
NEXT_PUBLIC_CAL_LINK=umair/visibility-review

# GA4 measurement ID. Loads unconditionally sitewide via components/analytics/Analytics.tsx.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
